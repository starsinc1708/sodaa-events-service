
GRPC_PORT=50051

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=events
POSTGRES_DSN=postgres://app:app@postgres:5432/events?sslmode=disable

KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=events
KAFKA_DLQ_TOPIC=events.dlq
KAFKA_GROUP_ID=event-stats-worker

CLICKHOUSE_USER=app
CLICKHOUSE_PASSWORD=app
CLICKHOUSE_DB=analytics
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_ENABLED=false

RATE_LIMIT_PER_MINUTE=60
